#!/usr/bin/env bash
set -euo pipefail

export LITELLM_MASTER_KEY="${LITELLM_MASTER_KEY:-sk-local-dev}"

GATEWAY_URL="${AI_LAB_GATEWAY_URL:-http://localhost:4000}"

usage() {
  cat <<USAGE
AI Dev Workstation

Usage:
  ai                                      Start/check the local AI workstation
  ai ask "prompt"                         Ask using the default fast route
  ai ask --mode fast "prompt"             Ask using the fast route
  ai ask --mode capable "prompt"          Ask using the capable route
  ai ask --mode code "prompt"             Ask using the code route
  ai routes                               List available gateway routes
  ai status                               Check local workstation status
  ai down                                 Stop local gateway and MLX servers

Operator commands remain available through just.
USAGE
}

ensure_ready() {
  just mlx-up >/dev/null
  just ai-up >/dev/null
}

ask_model() {
  local model="$1"
  local prompt="$2"

  curl -fsS "${GATEWAY_URL}/v1/chat/completions" \
    -H "Authorization: Bearer ${LITELLM_MASTER_KEY}" \
    -H "Content-Type: application/json" \
    -d "$(
      .venv/bin/python -c '
import json, sys
print(json.dumps({
  "model": sys.argv[1],
  "messages": [{"role": "user", "content": sys.argv[2]}]
}))
' "$model" "$prompt"
    )" | jq -r '.choices[0].message.content'
}

cmd="${1:-}"

case "$cmd" in
  "")
    ensure_ready
    echo "AI Dev Workstation is ready."
    echo
    usage
    ;;

  ask)
    shift

    mode="fast"

    if [[ "${1:-}" == "--mode" ]]; then
      mode="${2:-}"
      shift 2
    fi

    case "$mode" in
      fast)
        model="local-fast"
        ;;
      capable)
        model="local-capable-mlx"
        ;;
      code)
        model="local-code-mlx"
        ;;
      *)
        echo "Unknown mode: $mode" >&2
        echo "Supported modes: fast, capable, code" >&2
        exit 2
        ;;
    esac

    test "$#" -gt 0 || { echo "Usage: ai ask [--mode fast|capable|code] \"prompt\"" >&2; exit 2; }

    ensure_ready
    ask_model "$model" "$*"
    ;;

  fast)
    shift
    test "$#" -gt 0 || { echo "Usage: ai fast \"prompt\"" >&2; exit 2; }
    ensure_ready
    ask_model "local-fast" "$*"
    ;;

  capable)
    shift
    test "$#" -gt 0 || { echo "Usage: ai capable \"prompt\"" >&2; exit 2; }
    ensure_ready
    ask_model "local-capable-mlx" "$*"
    ;;

  code)
    shift
    test "$#" -gt 0 || { echo "Usage: ai code \"prompt\"" >&2; exit 2; }
    ensure_ready
    ask_model "local-code-mlx" "$*"
    ;;

  routes)
    ensure_ready
    just gateway-routes
    ;;

  status)
    echo "AI Dev Workstation Status"
    echo

    echo "Profile:    macos-work"
    echo "Posture:    local-first"

    if curl -fsS "${GATEWAY_URL}/v1/models" \
      -H "Authorization: Bearer ${LITELLM_MASTER_KEY}" >/dev/null 2>&1; then
      echo "Gateway:    running"
    else
      echo "Gateway:    not reachable"
      echo "            Try: just ai-up"
    fi

    fast_ready="not ready"
    capable_ready="not ready"
    code_ready="not ready"

    if lsof -nP -iTCP:8080 -sTCP:LISTEN >/dev/null 2>&1; then
      fast_ready="ready"
    fi

    if lsof -nP -iTCP:8081 -sTCP:LISTEN >/dev/null 2>&1; then
      capable_ready="ready"
    fi

    if lsof -nP -iTCP:8082 -sTCP:LISTEN >/dev/null 2>&1; then
      code_ready="ready"
    fi

    echo "Local:      fast (${fast_ready}), capable (${capable_ready}), code (${code_ready})"

    if [[ "${fast_ready}" != "ready" || "${capable_ready}" != "ready" || "${code_ready}" != "ready" ]]; then
      echo "            Try: just mlx-up"
    fi

    echo "Frontier:   not configured"
    echo "Routes:     local-fast, local-capable-mlx, local-code-mlx"
    echo "Last route: not recorded yet"
    ;;

  down)
    just ai-down
    just mlx-down
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
