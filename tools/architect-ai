#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# architect-ai
# ------------------------------------------------------------------------------
# Role-specific CLI wrapper for architecture-focused AI workflows.
#
# Uses ask-ollama as the core AI engine and automatically applies:
# - architect persona
# - writing style guidance
# - optional domain context, such as banking
# - automatic model routing
#
# Supports common architecture workflows:
# - explain
# - summary
# - compare
# - risks
# - discovery
# - talking-points
# - challenge
# - position
#
# Example:
#   architect-ai explain "RAG"
#   architect-ai banking explain "RAG"
#   architect-ai banking compare "OpenShift AI vs SageMaker"
# ==============================================================================


# ==============================================================================
# 1. BASIC SCRIPT CONFIGURATION
# ==============================================================================

VERSION="0.3.0"
SCRIPT_NAME="$(basename "$0")"

DEFAULT_PERSONA="architect"
DEFAULT_STYLE="writing-style"


# ==============================================================================
# 2. RUNTIME DEFAULTS
# ==============================================================================

DOMAIN=""
DOMAIN_ARGS=""

COMMAND=""
TOPIC=""
PROMPT=""


# ==============================================================================
# 3. HELP AND ERROR HANDLING
# ==============================================================================

show_help() {
  cat <<EOF
Usage:
  $SCRIPT_NAME [DOMAIN] COMMAND TOPIC

Optional Domain:
  banking              Add banking / financial services context

Commands:
  explain              Explain a concept for an architecture audience
  summary              Create an executive-level summary
  compare              Compare technologies or approaches
  risks                Identify risks, objections, and governance concerns
  discovery            Generate customer discovery questions
  talking-points       Create concise talking points
  challenge            Challenge assumptions and identify blind spots
  position             Create positioning guidance for a customer conversation

Options:
  -h, --help           Show this help message
  -v, --version        Display script version

Examples:
  $SCRIPT_NAME explain "RAG"
  $SCRIPT_NAME summary "platform engineering"
  $SCRIPT_NAME compare "OpenShift AI vs SageMaker"
  $SCRIPT_NAME risks "self-hosted AI platform"
  $SCRIPT_NAME discovery "enterprise AI adoption"
  $SCRIPT_NAME talking-points "OpenShift AI for platform teams"
  $SCRIPT_NAME challenge "AI platform operating model"
  $SCRIPT_NAME position "OpenShift AI for regulated enterprises"

Banking examples:
  $SCRIPT_NAME banking explain "RAG"
  $SCRIPT_NAME banking compare "OpenShift AI vs SageMaker"
  $SCRIPT_NAME banking risks "self-hosted AI platform"
  $SCRIPT_NAME banking discovery "enterprise AI adoption"
EOF
}

handle_error() {
  echo "Error: $1" >&2
  exit 1
}


# ==============================================================================
# 4. VALIDATE DEPENDENCIES
# ==============================================================================

if ! command -v ask-ollama >/dev/null 2>&1; then
  handle_error "ask-ollama not found in PATH. Ensure ~/projects/ai-lab/tools is in your PATH."
fi


# ==============================================================================
# 5. PROMPT TEMPLATE BUILDER
# ------------------------------------------------------------------------------
# Converts a high-level architecture workflow command into a structured prompt.
#
# The goal is not to create generic AI responses. The goal is to produce useful
# architecture-oriented material that supports customer conversations, decision
# framing, discovery, and practical enterprise technology thinking.
# ==============================================================================

build_workflow_prompt() {
  local command="$1"
  local topic="$2"

  case "$command" in
    explain)
      cat <<EOF
Explain '$topic' for an experienced enterprise and pre-sales architect.

Use this structure:
1. Plain-English explanation
2. Why it matters
3. Where it fits architecturally
4. Key trade-offs
5. Risks or constraints
6. Customer relevance
7. Practical adoption considerations

Avoid unnecessary low-level implementation detail unless it affects architecture, risk, governance, or operating model decisions.
EOF
      ;;

    summary)
      cat <<EOF
Create a concise executive-level summary on '$topic'.

Use this structure:
1. Executive summary
2. Why this matters now
3. Business value
4. Key risks or considerations
5. Architecture and operating model implications
6. Recommended next step

Keep the language clear, credible, and suitable for senior technology leadership.
EOF
      ;;

    compare)
      cat <<EOF
Compare '$topic' from an enterprise architecture and pre-sales perspective.

Use this structure:
1. Summary view
2. Option or approach comparison
3. Key architecture trade-offs
4. Operating model implications
5. Security, governance, and risk considerations
6. Integration and adoption considerations
7. Best-fit scenarios
8. Recommendation framing

Avoid a generic feature-by-feature comparison. Focus on practical decision-making, customer outcomes, and enterprise adoption realities.
EOF
      ;;

    risks)
      cat <<EOF
Identify the likely risks, objections, governance concerns, operational considerations, and adoption challenges for '$topic'.

Use this structure:
1. Executive concerns
2. Architecture and technology risks
3. Security and governance risks
4. Operating model impacts
5. Adoption and change risks
6. Likely customer objections
7. Questions to ask
8. Practical next steps

Focus on realistic enterprise concerns rather than theoretical risks.
EOF
      ;;

    discovery)
      cat <<EOF
Generate practical customer discovery questions for '$topic'.

Use this structure:
1. Strategy and business outcome questions
2. Current-state questions
3. Architecture and integration questions
4. Security, governance, and risk questions
5. Operating model and ownership questions
6. Platform and delivery questions
7. Decision criteria questions
8. Useful follow-up prompts

The questions should help an architect understand context, constraints, motivation, risks, and decision drivers.
EOF
      ;;

    talking-points)
      cat <<EOF
Create concise talking points for '$topic' suitable for a customer or leadership conversation.

Use this structure:
1. Opening framing
2. Key messages
3. Business outcome angle
4. Architecture angle
5. Risk and governance angle
6. Practical adoption angle
7. Suggested closing point

Keep the talking points clear, credible, and easy to use in conversation.
EOF
      ;;

    challenge)
      cat <<EOF
Challenge the assumptions behind '$topic'.

Use this structure:
1. Likely assumptions being made
2. Hidden risks or blind spots
3. Questions that should be asked before proceeding
4. Alternative perspectives
5. Signals that the approach may not be suitable
6. Practical ways to test or validate the thinking
7. Balanced conclusion

Be constructive. The aim is to improve the quality of thinking, not to be negative for the sake of it.
EOF
      ;;

    position)
      cat <<EOF
Create positioning guidance for '$topic' suitable for a customer conversation.

Use this structure:
1. Simple positioning statement
2. Customer problem or opportunity
3. Why it matters
4. Business and architecture relevance
5. Operating model relevance
6. Likely objections
7. How to respond to those objections
8. Suggested conversation openers
9. Practical next step

Avoid marketing-heavy language. Focus on credible, outcome-oriented positioning.
EOF
      ;;

    *)
      handle_error "Unknown command: $command"
      ;;
  esac
}


# ==============================================================================
# 6. OPTIONS AND ARGUMENT PARSER
# ------------------------------------------------------------------------------
# This parser supports:
# - optional domain first, e.g. banking
# - command second, e.g. explain
# - topic as all remaining arguments
#
# Example:
#   architect-ai banking explain "RAG"
# ==============================================================================

[[ $# -lt 1 ]] && {
  show_help
  exit 1
}

case "$1" in
  -h|--help)
    show_help
    exit 0
    ;;

  -v|--version)
    echo "$SCRIPT_NAME version $VERSION"
    exit 0
    ;;
esac

if [[ "${1:-}" == "banking" ]]; then
  DOMAIN="banking"
  DOMAIN_ARGS="--domain banking"
  shift
fi

COMMAND="${1:-}"
shift || true
TOPIC="$*"


# ==============================================================================
# 7. VALIDATION
# ==============================================================================

[[ -z "$COMMAND" ]] && {
  show_help
  exit 1
}

[[ -z "$TOPIC" ]] && {
  handle_error "Missing topic. Example: $SCRIPT_NAME explain \"RAG\""
}


# ==============================================================================
# 8. BUILD FINAL WORKFLOW PROMPT
# ==============================================================================

PROMPT="$(build_workflow_prompt "$COMMAND" "$TOPIC")"


# ==============================================================================
# 9. SEND PROMPT TO ASK-OLLAMA
# ------------------------------------------------------------------------------
# ask-ollama handles:
# - model execution
# - automatic model routing
# - persona loading
# - writing style loading
# - optional domain context
# - memory
# - saving output
# ==============================================================================

ask-ollama \
  --auto \
  --persona "$DEFAULT_PERSONA" \
  --style "$DEFAULT_STYLE" \
  $DOMAIN_ARGS \
  "$PROMPT"