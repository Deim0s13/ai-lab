#!/usr/bin/env python3

"""
ai-bootstrap-check

Gateway-aware bootstrap check for AI Dev Workstation as Code.

This command checks the minimum Milestone 1 foundation:
- profile exists
- core config exists and parses
- LiteLLM config exists and parses
- gateway is reachable
- expected model group is visible
- gateway health reports at least one healthy endpoint

It does not print secrets.
It does not send prompts.
It does not call frontier providers.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.request
from dataclasses import dataclass
from pathlib import Path
from typing import Any

try:
    import yaml
except ModuleNotFoundError:
    print("Error: PyYAML is required to run ai-bootstrap-check.")
    print("Install inside the repo venv with: python -m pip install pyyaml")
    sys.exit(1)


REPO_ROOT = Path(__file__).resolve().parents[1]

REQUIRED_CONFIG_FILES = [
    "config/providers/providers.yaml",
    "config/models/aliases.yaml",
    "config/routing/routes.yaml",
    "config/policies/logging.yaml",
    "config/policies/sensitivity.yaml",
    "config/capabilities/capabilities.yaml",
]

LITELLM_CONFIG_FILE = "config/gateway/litellm/config.local.yaml"


@dataclass
class CheckResult:
    name: str
    status: str
    detail: str


def rel(path: Path) -> str:
    return str(path.relative_to(REPO_ROOT))


def load_yaml(path: Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as file:
        data = yaml.safe_load(file)

    if data is None:
        return {}

    if not isinstance(data, dict):
        raise ValueError("YAML file must contain a mapping")

    return data


def add(results: list[CheckResult], name: str, status: str, detail: str) -> None:
    results.append(CheckResult(name=name, status=status, detail=detail))


def check_profile(results: list[CheckResult], profile: str) -> None:
    path = REPO_ROOT / "profiles" / profile / "profile.yaml"

    if not path.exists():
        add(results, "profile", "FAIL", f"missing {rel(path)}")
        return

    try:
        load_yaml(path)
    except Exception as exc:
        add(results, "profile", "FAIL", f"invalid YAML in {rel(path)}: {exc}")
        return

    add(results, "profile", "OK", f"{rel(path)}")


def check_core_config(results: list[CheckResult]) -> None:
    for item in REQUIRED_CONFIG_FILES:
        path = REPO_ROOT / item

        if not path.exists():
            add(results, "core config", "FAIL", f"missing {item}")
            continue

        try:
            load_yaml(path)
        except Exception as exc:
            add(results, "core config", "FAIL", f"invalid YAML in {item}: {exc}")
            continue

        add(results, "core config", "OK", item)


def check_litellm_config(results: list[CheckResult]) -> dict[str, Any]:
    path = REPO_ROOT / LITELLM_CONFIG_FILE

    if not path.exists():
        add(results, "LiteLLM config", "FAIL", f"missing {LITELLM_CONFIG_FILE}")
        return {}

    try:
        data = load_yaml(path)
    except Exception as exc:
        add(results, "LiteLLM config", "FAIL", f"invalid YAML in {LITELLM_CONFIG_FILE}: {exc}")
        return {}

    add(results, "LiteLLM config", "OK", LITELLM_CONFIG_FILE)
    return data


def expected_model_group(results: list[CheckResult]) -> str:
    path = REPO_ROOT / "config" / "routing" / "routes.yaml"

    try:
        routes = load_yaml(path)
    except Exception as exc:
        add(results, "route model group", "FAIL", f"could not load routes.yaml: {exc}")
        return "local-fast"

    route_classes = routes.get("route_classes", {})
    local_fast = route_classes.get("local_fast", {})

    model_group = local_fast.get("gateway_model_group")

    if not model_group:
        add(results, "route model group", "FAIL", "local_fast has no gateway_model_group")
        return "local-fast"

    add(results, "route model group", "OK", f"local_fast -> {model_group}")
    return str(model_group)


def check_litellm_model_group(
    results: list[CheckResult],
    litellm_config: dict[str, Any],
    model_group: str,
) -> None:
    model_list = litellm_config.get("model_list", [])

    if not isinstance(model_list, list):
        add(results, "LiteLLM model group", "FAIL", "model_list is not a list")
        return

    configured = [
        item.get("model_name")
        for item in model_list
        if isinstance(item, dict)
    ]

    if model_group not in configured:
        add(results, "LiteLLM model group", "FAIL", f"{model_group} not configured")
        return

    add(results, "LiteLLM model group", "OK", f"{model_group} configured")


def http_get_json(url: str, api_key: str, timeout: float) -> tuple[int, dict[str, Any] | list[Any] | None, str | None]:
    request = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        method="GET",
    )

    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            raw = response.read().decode("utf-8")
            data = json.loads(raw) if raw else {}
            return response.status, data, None
    except urllib.error.HTTPError as exc:
        raw = exc.read().decode("utf-8", errors="replace")
        return exc.code, None, raw
    except Exception as exc:
        return 0, None, str(exc)


def check_gateway(
    results: list[CheckResult],
    gateway_url: str,
    api_key: str | None,
    model_group: str,
    timeout: float,
) -> None:
    if not api_key:
        add(
            results,
            "gateway auth",
            "FAIL",
            "LITELLM_MASTER_KEY is not set",
        )
        return

    add(results, "gateway auth", "OK", "LITELLM_MASTER_KEY is set; value not displayed")

    models_status, models_data, models_error = http_get_json(
        f"{gateway_url.rstrip('/')}/v1/models",
        api_key,
        timeout,
    )

    if models_status != 200 or not isinstance(models_data, dict):
        detail = models_error or f"unexpected status {models_status}"
        add(results, "gateway models", "FAIL", detail)
        return

    available_models = [
        item.get("id")
        for item in models_data.get("data", [])
        if isinstance(item, dict)
    ]

    if model_group not in available_models:
        add(
            results,
            "gateway models",
            "FAIL",
            f"{model_group} not listed by /v1/models",
        )
        return

    add(results, "gateway models", "OK", f"{model_group} listed by /v1/models")

    health_status, health_data, health_error = http_get_json(
        f"{gateway_url.rstrip('/')}/health",
        api_key,
        timeout,
    )

    if health_status != 200 or not isinstance(health_data, dict):
        detail = health_error or f"unexpected status {health_status}"
        add(results, "gateway health", "FAIL", detail)
        return

    healthy_count = health_data.get("healthy_count", 0)
    unhealthy_count = health_data.get("unhealthy_count", 0)

    if healthy_count < 1:
        add(
            results,
            "gateway health",
            "FAIL",
            f"healthy_count={healthy_count}, unhealthy_count={unhealthy_count}",
        )
        return

    add(
        results,
        "gateway health",
        "OK",
        f"healthy_count={healthy_count}, unhealthy_count={unhealthy_count}",
    )


def print_results(
    profile: str,
    gateway_url: str,
    model_group: str,
    results: list[CheckResult],
) -> int:
    print("AI Bootstrap Check")
    print()
    print(f"Profile: {profile}")
    print(f"Gateway URL: {gateway_url}")
    print(f"Expected model group: {model_group}")
    print()

    has_fail = False
    has_warn = False

    for result in results:
        if result.status == "FAIL":
            has_fail = True
        if result.status == "WARN":
            has_warn = True

        print(f"[{result.status}] {result.name}: {result.detail}")

    print()

    if has_fail:
        print("Status: FAIL")
        print()
        print("Next action:")
        print("- Fix the failed checks above.")
        print("- Confirm the LiteLLM gateway is running before retrying.")
        return 8

    if has_warn:
        print("Status: WARN")
        return 0

    print("Status: OK")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Run a gateway-aware bootstrap check for the AI Dev Workstation."
    )
    parser.add_argument(
        "--profile",
        default="macos-work",
        help="Profile to check. Default: macos-work",
    )
    parser.add_argument(
        "--gateway-url",
        default=os.environ.get("AI_LAB_GATEWAY_URL", "http://localhost:4000"),
        help="LiteLLM gateway URL. Default: AI_LAB_GATEWAY_URL or http://localhost:4000",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=5.0,
        help="HTTP timeout in seconds. Default: 5",
    )

    args = parser.parse_args()

    results: list[CheckResult] = []

    check_profile(results, args.profile)
    check_core_config(results)
    litellm_config = check_litellm_config(results)
    model_group = expected_model_group(results)
    check_litellm_model_group(results, litellm_config, model_group)

    check_gateway(
        results=results,
        gateway_url=args.gateway_url,
        api_key=os.environ.get("LITELLM_MASTER_KEY"),
        model_group=model_group,
        timeout=args.timeout,
    )

    return print_results(
        profile=args.profile,
        gateway_url=args.gateway_url,
        model_group=model_group,
        results=results,
    )


if __name__ == "__main__":
    raise SystemExit(main())
