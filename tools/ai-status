#!/usr/bin/env python3

from __future__ import annotations

import argparse
import sys
from pathlib import Path
from typing import Any

try:
    import yaml
except ModuleNotFoundError:
    print("Error: PyYAML is required to run ai-status.")
    print("Install with: python3 -m pip install --user pyyaml")
    sys.exit(1)


REPO_ROOT = Path(__file__).resolve().parents[1]

REQUIRED_CONFIG_FILES = [
    "config/providers/providers.yaml",
    "config/models/aliases.yaml",
    "config/routing/routes.yaml",
    "config/policies/logging.yaml",
    "config/policies/sensitivity.yaml",
    "config/capabilities/capabilities.yaml",
]


def load_yaml(path: Path) -> dict[str, Any]:
    if not path.exists():
        raise FileNotFoundError(path)

    with path.open("r", encoding="utf-8") as file:
        data = yaml.safe_load(file)

    if data is None:
        return {}

    if not isinstance(data, dict):
        raise ValueError(f"{path} must contain a YAML mapping")

    return data


def ok_fail(value: bool) -> str:
    return "OK" if value else "FAIL"


def resolve_profile(profile_name: str) -> Path:
    return REPO_ROOT / "profiles" / profile_name / "profile.yaml"


def check_config_files() -> list[tuple[str, bool]]:
    results: list[tuple[str, bool]] = []

    for relative_path in REQUIRED_CONFIG_FILES:
        path = REPO_ROOT / relative_path
        results.append((relative_path, path.exists()))

    return results


def print_list(title: str, values: list[str] | None) -> None:
    print(f"{title}:")
    if not values:
        print("- none")
        return

    for value in values:
        print(f"- {value}")


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Show AI workstation profile and configuration status."
    )
    parser.add_argument(
        "--profile",
        required=True,
        help="Profile to inspect, for example macos-work or windows-personal.",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Show additional profile detail.",
    )

    args = parser.parse_args()

    profile_path = resolve_profile(args.profile)

    print("AI Lab Status")
    print()

    if not profile_path.exists():
        print(f"Profile: {args.profile}")
        print("Status: FAIL")
        print()
        print(f"Error: profile file not found: {profile_path.relative_to(REPO_ROOT)}")
        print()
        print("Next action:")
        print(f"- create profiles/{args.profile}/profile.yaml")
        return 3

    try:
        profile = load_yaml(profile_path)
    except Exception as exc:
        print(f"Profile: {args.profile}")
        print("Status: FAIL")
        print()
        print(f"Error: could not load profile YAML: {exc}")
        return 3

    profile_status = profile.get("status", "unknown")
    risk_posture = profile.get("device", {}).get("risk_posture", "unknown")
    local_runtimes = profile.get("local_runtimes", {})
    runtime_access = profile.get("runtime_access", {})
    providers = profile.get("providers", {})
    approved_workspaces = profile.get("approved_workspaces", [])
    secrets = profile.get("secrets", {})
    context = profile.get("context", {})

    print(f"Profile: {args.profile}")
    print(f"Profile file: {profile_path.relative_to(REPO_ROOT)}")
    print(f"Profile status: {profile_status}")
    print(f"Risk posture: {risk_posture}")
    print()

    print("Config files:")
    config_results = check_config_files()
    missing_config = False

    for relative_path, exists in config_results:
        print(f"- {relative_path}: {ok_fail(exists)}")
        if not exists:
            missing_config = True

    print()

    print("Gateway:")
    print("- status: NOT CHECKED")
    print("- note: live gateway health check is not implemented yet")
    print()

    print("Local runtimes:")
    preferred_runtimes = local_runtimes.get("preferred", [])
    fallback_runtimes = local_runtimes.get("fallback", [])

    if preferred_runtimes:
        for runtime in preferred_runtimes:
            print(f"- {runtime}: NOT CHECKED")
    else:
        print("- preferred runtime: not defined")

    if fallback_runtimes:
        for runtime in fallback_runtimes:
            print(f"- {runtime}: NOT CHECKED fallback")

    print()

    print("Runtime access:")
    print(f"- default: {runtime_access.get('default', 'unknown')}")
    print(f"- direct local fallback: {runtime_access.get('direct_local_fallback', False)}")
    print(f"- direct frontier fallback: {runtime_access.get('direct_frontier_fallback', False)}")
    print()

    print("Secrets:")
    print(f"- source: {secrets.get('source', 'unknown')}")
    print(f"- fallback: {secrets.get('fallback', 'unknown')}")

    required_secrets = secrets.get("required", [])
    optional_secrets = secrets.get("optional", [])

    print(f"- required secrets defined: {len(required_secrets)}")
    print(f"- optional secrets defined: {len(optional_secrets)}")
    print("- values: not displayed")
    print("- availability: NOT CHECKED")
    print()

    print("Providers:")
    if not providers:
        print("- none defined")
    else:
        for group_name, provider_values in providers.items():
            if isinstance(provider_values, list):
                print(f"- {group_name}: {', '.join(provider_values)}")
            else:
                print(f"- {group_name}: {provider_values}")
    print()

    print("Approved workspaces:")
    if approved_workspaces:
        for workspace in approved_workspaces:
            name = workspace.get("name", "unknown")
            purpose = workspace.get("purpose", "unknown")
            print(f"- {name}: {purpose}")
    else:
        print("- none")
    print()

    print("Context:")
    print_list("Allowed", context.get("allowed", []))
    print_list("Blocked", context.get("blocked", []))
    print()

    if args.verbose:
        print("Validation expectations:")
        validation = profile.get("validation", {})
        print_list("Required", validation.get("required", []))
        print_list("Optional", validation.get("optional", []))
        print()

    if missing_config:
        print("Status: WARN")
        print()
        print("Next action:")
        print("- create missing config files listed above")
        return 0

    print("Status: OK")
    print()
    print("Note:")
    print("- This is an initial Milestone 1 status stub.")
    print("- Live gateway, runtime and secret checks will be added later.")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
