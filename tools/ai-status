#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# ai-status
# ------------------------------------------------------------------------------
# Health check and safe remediation tool for the local AI workstation.
#
# Checks:
# - Ollama service/process
# - Ollama API reachability
# - available models
# - active model processor usage
# - NVIDIA GPU visibility
# - Open WebUI Podman container status
#
# Safe remediation with --fix:
# - start Ollama service if stopped
# - restart Ollama service if API is unreachable
# - start Open WebUI container if stopped
# - restart Open WebUI container if HTTP endpoint is unreachable
#
# It does NOT:
# - change GPU drivers
# - modify Ollama service files
# - download models
# - recreate containers
# - change network configuration
#
# Examples:
#   ai-status
#   ai-status --probe
#   ai-status --fix
#   ai-status --fix --probe
# ==============================================================================


# ==============================================================================
# 1. BASIC SCRIPT CONFIGURATION
# ==============================================================================

VERSION="0.2.0"
SCRIPT_NAME="$(basename "$0")"

CONFIG_FILE="$HOME/.config/ask-ollama/config"

OLLAMA_URL="http://127.0.0.1:11434"
DEFAULT_MODEL="qwen3:14b"

OPEN_WEBUI_CONTAINER="open-webui"
OPEN_WEBUI_URL="http://127.0.0.1:8080"

RUN_PROBE=false
RUN_FIX=false

TAGS_FILE="$(mktemp)"
trap 'rm -f "$TAGS_FILE"' EXIT


# ==============================================================================
# 2. LOAD OPTIONAL CONFIG
# ------------------------------------------------------------------------------
# Reuses ask-ollama configuration if present.
# ==============================================================================

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$CONFIG_FILE" || true
fi


# ==============================================================================
# 3. HELP AND OUTPUT FUNCTIONS
# ==============================================================================

show_help() {
  cat <<EOF
Usage:
  $SCRIPT_NAME [OPTIONS]

Options:
  -h, --help       Show this help message
  -v, --version    Display script version
  --probe          Run a lightweight model prompt before checking GPU usage
  --fix            Apply safe remediation actions

Examples:
  $SCRIPT_NAME
  $SCRIPT_NAME --probe
  $SCRIPT_NAME --fix
  $SCRIPT_NAME --fix --probe
EOF
}

ok() {
  echo "✅ $1"
}

warn() {
  echo "⚠️  $1"
}

fail() {
  echo "❌ $1"
}

action() {
  echo "🔧 $1"
}

section() {
  echo ""
  echo "== $1 =="
}


# ==============================================================================
# 4. OPTIONS PARSER
# ==============================================================================

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;

    -v|--version)
      echo "$SCRIPT_NAME version $VERSION"
      exit 0
      ;;

    --probe)
      RUN_PROBE=true
      ;;

    --fix)
      RUN_FIX=true
      ;;

    *)
      fail "Unknown option: $1"
      show_help
      exit 1
      ;;
  esac

  shift
done


# ==============================================================================
# 5. UTILITY FUNCTIONS
# ==============================================================================

ollama_service_exists() {
  systemctl list-unit-files --type=service 2>/dev/null | grep -q '^ollama.service'
}

ollama_service_running() {
  systemctl is-active --quiet ollama 2>/dev/null
}

ollama_process_running() {
  pgrep -x ollama >/dev/null 2>&1
}

ollama_api_reachable() {
  curl -fsS --max-time 5 "$OLLAMA_URL/api/tags" -o "$TAGS_FILE" 2>/dev/null
}

start_ollama() {
  if ollama_service_exists; then
    action "Starting Ollama service"
    sudo systemctl start ollama
  else
    warn "Ollama systemd service not found. Start Ollama manually with: ollama serve"
    return 1
  fi
}

restart_ollama() {
  if ollama_service_exists; then
    action "Restarting Ollama service"
    sudo systemctl restart ollama
  else
    warn "Ollama systemd service not found. Restart Ollama manually."
    return 1
  fi
}

open_webui_container_exists() {
  podman ps -a --format '{{.Names}}' 2>/dev/null | grep -Fxq "$OPEN_WEBUI_CONTAINER"
}

open_webui_container_running() {
  podman ps --format '{{.Names}}' 2>/dev/null | grep -Fxq "$OPEN_WEBUI_CONTAINER"
}

open_webui_reachable() {
  curl -fsS --max-time 5 "$OPEN_WEBUI_URL" >/dev/null 2>&1
}

start_open_webui() {
  action "Starting Open WebUI container"
  podman start "$OPEN_WEBUI_CONTAINER" >/dev/null
}

restart_open_webui() {
  action "Restarting Open WebUI container"
  podman restart "$OPEN_WEBUI_CONTAINER" >/dev/null
}


# ==============================================================================
# 6. OLLAMA SERVICE / PROCESS CHECK
# ==============================================================================

section "Ollama Runtime"

if command -v ollama >/dev/null 2>&1; then
  ok "Ollama CLI found: $(command -v ollama)"
else
  fail "Ollama CLI not found"
  exit 1
fi

if ollama_service_exists; then
  if ollama_service_running; then
    ok "Ollama service is running"
  else
    fail "Ollama service is not running"

    if [[ "$RUN_FIX" == true ]]; then
      start_ollama || true
      sleep 3

      if ollama_service_running; then
        ok "Ollama service started successfully"
      else
        fail "Ollama service still not running after attempted fix"
      fi
    fi
  fi
else
  if ollama_process_running; then
    ok "Ollama process is running"
  else
    fail "Ollama process is not running"

    if [[ "$RUN_FIX" == true ]]; then
      warn "No systemd service found, so ai-status will not start Ollama automatically."
      warn "Recommended: install/configure Ollama as a systemd service."
    fi
  fi
fi


# ==============================================================================
# 7. OLLAMA API CHECK
# ==============================================================================

section "Ollama API"

if ollama_api_reachable; then
  ok "Ollama API reachable at $OLLAMA_URL"
else
  fail "Ollama API not reachable at $OLLAMA_URL"

  if [[ "$RUN_FIX" == true ]]; then
    restart_ollama || true
    sleep 5

    if ollama_api_reachable; then
      ok "Ollama API reachable after restart"
    else
      fail "Ollama API still unreachable after attempted fix"
    fi
  fi
fi


# ==============================================================================
# 8. AVAILABLE MODELS
# ==============================================================================

section "Available Models"

if [[ -s "$TAGS_FILE" ]] && command -v jq >/dev/null 2>&1; then
  MODELS="$(jq -r '.models[].name' "$TAGS_FILE" 2>/dev/null || true)"

  if [[ -n "$MODELS" ]]; then
    echo "$MODELS" | sed 's/^/- /'
  else
    warn "No models found via API"
  fi
else
  ollama list || warn "Unable to list models"
fi


# ==============================================================================
# 9. GPU VISIBILITY CHECK
# ==============================================================================

section "GPU"

if command -v nvidia-smi >/dev/null 2>&1; then
  GPU_NAME="$(nvidia-smi --query-gpu=name --format=csv,noheader | head -n 1)"
  GPU_DRIVER="$(nvidia-smi --query-gpu=driver_version --format=csv,noheader | head -n 1)"
  GPU_MEMORY="$(nvidia-smi --query-gpu=memory.total --format=csv,noheader | head -n 1)"

  ok "GPU detected: $GPU_NAME"
  echo "Driver: $GPU_DRIVER"
  echo "Memory: $GPU_MEMORY"
else
  fail "nvidia-smi not found. WSL2 may not have GPU visibility."

  if [[ "$RUN_FIX" == true ]]; then
    warn "GPU visibility requires Windows NVIDIA driver / WSL configuration."
    warn "No automatic fix applied."
  fi
fi


# ==============================================================================
# 10. OPTIONAL INFERENCE PROBE
# ------------------------------------------------------------------------------
# This loads the default model and runs a tiny prompt, making ollama ps useful.
# ==============================================================================

if [[ "$RUN_PROBE" == true ]]; then
  section "Inference Probe"

  echo "Running lightweight prompt with model: $DEFAULT_MODEL"

  if timeout 120s ollama run "$DEFAULT_MODEL" "Reply with exactly: ok" >/dev/null 2>&1; then
    ok "Inference probe completed"
  else
    warn "Inference probe did not complete within 120 seconds"
  fi
fi


# ==============================================================================
# 11. ACTIVE MODEL / PROCESSOR CHECK
# ==============================================================================

section "Active Models"

OLLAMA_PS_OUTPUT="$(ollama ps 2>/dev/null || true)"
ACTIVE_MODELS="$(echo "$OLLAMA_PS_OUTPUT" | awk 'NR > 1')"

if [[ -n "$ACTIVE_MODELS" ]]; then
  echo "$OLLAMA_PS_OUTPUT"

  if echo "$OLLAMA_PS_OUTPUT" | grep -qi "GPU"; then
    ok "Ollama reports GPU usage"
  elif echo "$OLLAMA_PS_OUTPUT" | grep -qi "CPU"; then
    warn "Ollama reports CPU usage"

    if [[ "$RUN_FIX" == true ]]; then
      warn "CPU-only execution is not auto-fixed."
      warn "Check Ollama service environment, NVIDIA WSL support, and CUDA visibility."
    fi
  else
    warn "Unable to determine processor usage from ollama ps"
  fi
else
  warn "No active models loaded. Run 'ai-status --probe' to test processor usage."
fi


# ==============================================================================
# 12. OPEN WEBUI CONTAINER CHECK
# ==============================================================================

section "Open WebUI"

if command -v podman >/dev/null 2>&1; then
  if open_webui_container_running; then
    ok "Open WebUI container is running"
  elif open_webui_container_exists; then
    warn "Open WebUI container exists but is not running"

    if [[ "$RUN_FIX" == true ]]; then
      start_open_webui || true
      sleep 5

      if open_webui_container_running; then
        ok "Open WebUI container started successfully"
      else
        fail "Open WebUI container still not running after attempted fix"
      fi
    fi
  else
    warn "Open WebUI container not found"

    if [[ "$RUN_FIX" == true ]]; then
      warn "Container does not exist. No automatic creation performed."
    fi
  fi
else
  warn "Podman not found"
fi

if open_webui_reachable; then
  ok "Open WebUI reachable at $OPEN_WEBUI_URL"
else
  warn "Open WebUI not reachable at $OPEN_WEBUI_URL"

  if [[ "$RUN_FIX" == true ]] && command -v podman >/dev/null 2>&1 && open_webui_container_exists; then
    restart_open_webui || true
    sleep 8

    if open_webui_reachable; then
      ok "Open WebUI reachable after restart"
    else
      warn "Open WebUI still unreachable after attempted fix"
    fi
  fi
fi


# ==============================================================================
# 13. SUMMARY
# ==============================================================================

section "Summary"

echo "AI workstation status check complete."
echo ""
echo "Useful commands:"
echo "  ai-status"
echo "  ai-status --probe"
echo "  ai-status --fix"
echo "  ai-status --fix --probe"