#!/usr/bin/env python3

"""
ai-route

Initial route explanation command for AI Dev Workstation as Code.

This is a Milestone 1 stub. It explains expected routing behaviour from
profile and config files without calling any model provider.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path
from typing import Any

try:
    import yaml
except ModuleNotFoundError:
    print("Error: PyYAML is required to run ai-route.")
    print("Install inside the repo venv with: python -m pip install pyyaml")
    sys.exit(1)


REPO_ROOT = Path(__file__).resolve().parents[1]

VALID_TASKS = {
    "quick_question",
    "summarise",
    "rewrite",
    "coding_explain",
    "coding_generate",
    "coding_debug",
    "architecture_review",
    "writing_polish",
    "research_synthesis",
    "model_selection",
    "agent_workflow",
}

VALID_SENSITIVITY_LEVELS = {
    "public",
    "internal",
    "customer",
    "personal",
    "restricted",
}


def load_yaml(path: Path) -> dict[str, Any]:
    if not path.exists():
        raise FileNotFoundError(path)

    with path.open("r", encoding="utf-8") as file:
        data = yaml.safe_load(file)

    if data is None:
        return {}

    if not isinstance(data, dict):
        raise ValueError(f"{path} must contain a YAML mapping")

    return data


def load_profile(profile_name: str) -> dict[str, Any]:
    profile_path = REPO_ROOT / "profiles" / profile_name / "profile.yaml"

    if not profile_path.exists():
        print("Route check failed.")
        print()
        print(f"Profile: {profile_name}")
        print("Status: FAIL")
        print()
        print(f"Error: profile file not found: {profile_path.relative_to(REPO_ROOT)}")
        raise SystemExit(3)

    try:
        return load_yaml(profile_path)
    except Exception as exc:
        print("Route check failed.")
        print()
        print(f"Profile: {profile_name}")
        print("Status: FAIL")
        print()
        print(f"Error: could not load profile YAML: {exc}")
        raise SystemExit(3)


def load_config(relative_path: str) -> dict[str, Any]:
    path = REPO_ROOT / relative_path

    try:
        return load_yaml(path)
    except FileNotFoundError:
        print("Route check failed.")
        print()
        print(f"Missing config file: {relative_path}")
        raise SystemExit(8)
    except Exception as exc:
        print("Route check failed.")
        print()
        print(f"Invalid config file: {relative_path}")
        print(f"Error: {exc}")
        raise SystemExit(8)


def get_profile_routes(routes_config: dict[str, Any], profile_name: str) -> dict[str, Any]:
    profiles = routes_config.get("profiles", {})
    profile_routes = profiles.get(profile_name)

    if not isinstance(profile_routes, dict):
        print("Route check failed.")
        print()
        print(f"Profile: {profile_name}")
        print("Status: FAIL")
        print()
        print("Error: no routing config found for profile")
        raise SystemExit(8)

    return profile_routes


def default_sensitivity_for_profile(
    sensitivity_config: dict[str, Any], profile_name: str
) -> str:
    defaults = sensitivity_config.get("profile_defaults", {})
    profile_default = defaults.get(profile_name, {})

    return profile_default.get("default_sensitivity", "public")


def route_for_task(
    profile_routes: dict[str, Any],
    task: str,
    force_local: bool,
    best: bool,
) -> tuple[str, str]:
    task_policy = profile_routes.get("task_policy", {}).get(task, {})

    if force_local:
        return "local_fast", "local flag forces local-only routing"

    if best and task_policy.get("escalation_route"):
        return task_policy["escalation_route"], "best flag allows configured escalation route"

    if task_policy.get("preferred_route"):
        return task_policy["preferred_route"], "task policy defines a preferred route"

    return "local_fast", "no task-specific route found, falling back to local_fast"


def apply_sensitivity_policy(
    profile_routes: dict[str, Any],
    sensitivity: str,
    selected_route: str,
) -> tuple[str, str, bool]:
    sensitivity_policy = profile_routes.get("sensitivity_policy", {}).get(sensitivity, {})

    blocked_routes = sensitivity_policy.get("blocked_routes", [])
    allowed_routes = sensitivity_policy.get("allowed_routes", [])

    if selected_route in blocked_routes:
        return "blocked", f"{selected_route} is blocked for sensitivity={sensitivity}", True

    if allowed_routes and selected_route not in allowed_routes:
        fallback_route = allowed_routes[0]
        return (
            fallback_route,
            f"{selected_route} is not allowed for sensitivity={sensitivity}; using {fallback_route}",
            False,
        )

    return selected_route, f"{selected_route} is allowed for sensitivity={sensitivity}", False


def provider_priority_for_route(
    profile_routes: dict[str, Any],
    selected_route: str,
) -> list[str]:
    provider_priority = profile_routes.get("provider_priority", {})

    if selected_route.startswith("local_"):
        return provider_priority.get("local", [])

    if selected_route == "approved_work":
        return provider_priority.get("approved_work", [])

    if selected_route.startswith("frontier_"):
        return provider_priority.get("frontier", [])

    return []


def print_route_result(
    profile_name: str,
    profile: dict[str, Any],
    task: str,
    sensitivity: str,
    requested_mode: str,
    selected_route: str,
    provider_priority: list[str],
    explanation: list[str],
    blocked: bool,
    explain: bool,
) -> int:
    print("AI Route")
    print()
    print(f"Profile: {profile_name}")
    print(f"Profile status: {profile.get('status', 'unknown')}")
    print(f"Task type: {task}")
    print(f"Sensitivity: {sensitivity}")
    print(f"Requested mode: {requested_mode}")
    print()

    if blocked:
        print("Selected route: blocked")
        print("Status: BLOCKED")
        print()
        print("Reason:")
        for item in explanation:
            print(f"- {item}")
        return 7

    print(f"Selected route: {selected_route}")

    if provider_priority:
        print("Provider priority:")
        for provider in provider_priority:
            print(f"- {provider}")
    else:
        print("Provider priority:")
        print("- none resolved")

    print()
    print("Status: OK")

    if explain:
        print()
        print("Reason:")
        for item in explanation:
            print(f"- {item}")

    print()
    print("Note:")
    print("- This command only explains routing.")
    print("- No prompt was sent to any model provider.")

    return 0


def run_route_tests() -> int:
    tests = [
        {
            "id": "route-001",
            "profile": "macos-work",
            "task": "summarise",
            "sensitivity": "internal",
            "expected": "local_fast",
        },
        {
            "id": "route-002",
            "profile": "macos-work",
            "task": "architecture_review",
            "sensitivity": "customer",
            "expected": "approved_work",
            "best": True,
        },
        {
            "id": "route-003",
            "profile": "macos-work",
            "task": "summarise",
            "sensitivity": "restricted",
            "expected": "local_fast",
        },
        {
            "id": "route-004",
            "profile": "windows-personal",
            "task": "coding_debug",
            "sensitivity": "personal",
            "expected": "frontier_code",
            "best": True,
        },
    ]

    routes_config = load_config("config/routing/routes.yaml")
    sensitivity_config = load_config("config/policies/sensitivity.yaml")

    print("Routing validation")
    print()

    failures = 0

    for test in tests:
        profile_name = test["profile"]
        task = test["task"]
        sensitivity = test.get(
            "sensitivity",
            default_sensitivity_for_profile(sensitivity_config, profile_name),
        )
        best = test.get("best", False)

        profile_routes = get_profile_routes(routes_config, profile_name)
        initial_route, _ = route_for_task(profile_routes, task, False, best)
        selected_route, _, blocked = apply_sensitivity_policy(
            profile_routes, sensitivity, initial_route
        )

        expected = test["expected"]
        passed = selected_route == expected and not blocked

        if not passed:
            failures += 1

        result = "PASS" if passed else "FAIL"
        print(
            f"{test['id']}  {profile_name:<17} "
            f"{task}/{sensitivity:<24} "
            f"expected={expected:<16} actual={selected_route:<16} {result}"
        )

    print()
    if failures:
        print(f"Result: FAIL ({failures} failed)")
        return 8

    print("Result: PASS")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Explain AI routing decisions without calling model providers."
    )
    parser.add_argument(
        "prompt",
        nargs="?",
        help="Optional prompt text. It is not sent anywhere by this command.",
    )
    parser.add_argument("--profile", help="Profile to evaluate.")
    parser.add_argument("--task", default="quick_question", help="Task type to evaluate.")
    parser.add_argument("--sensitivity", help="Sensitivity level to evaluate.")
    parser.add_argument("--local", action="store_true", help="Force local-only routing.")
    parser.add_argument("--best", action="store_true", help="Use best allowed route.")
    parser.add_argument("--explain", action="store_true", help="Explain routing decision.")
    parser.add_argument("--test", action="store_true", help="Run routing validation tests.")

    args = parser.parse_args()

    if args.test:
        return run_route_tests()

    if not args.profile:
        print("Error: --profile is required unless --test is used.")
        return 2

    if args.task not in VALID_TASKS:
        print(f"Error: invalid task type: {args.task}")
        print()
        print("Valid task types:")
        for task in sorted(VALID_TASKS):
            print(f"- {task}")
        return 2

    profile = load_profile(args.profile)
    routes_config = load_config("config/routing/routes.yaml")
    sensitivity_config = load_config("config/policies/sensitivity.yaml")

    sensitivity = args.sensitivity or default_sensitivity_for_profile(
        sensitivity_config, args.profile
    )

    if sensitivity not in VALID_SENSITIVITY_LEVELS:
        print(f"Error: invalid sensitivity level: {sensitivity}")
        print()
        print("Valid sensitivity levels:")
        for level in sorted(VALID_SENSITIVITY_LEVELS):
            print(f"- {level}")
        return 2

    profile_routes = get_profile_routes(routes_config, args.profile)

    requested_mode = "local" if args.local else "best" if args.best else "default"

    explanation: list[str] = []
    explanation.append(f"profile {args.profile} loaded successfully")
    explanation.append(f"task type is {args.task}")
    explanation.append(f"sensitivity is {sensitivity}")

    initial_route, route_reason = route_for_task(
        profile_routes,
        args.task,
        args.local,
        args.best,
    )
    explanation.append(route_reason)

    selected_route, sensitivity_reason, blocked = apply_sensitivity_policy(
        profile_routes,
        sensitivity,
        initial_route,
    )
    explanation.append(sensitivity_reason)

    provider_priority = provider_priority_for_route(profile_routes, selected_route)

    if args.prompt:
        explanation.append("prompt text was provided but not sent to any provider")

    return print_route_result(
        profile_name=args.profile,
        profile=profile,
        task=args.task,
        sensitivity=sensitivity,
        requested_mode=requested_mode,
        selected_route=selected_route,
        provider_priority=provider_priority,
        explanation=explanation,
        blocked=blocked,
        explain=args.explain,
    )


if __name__ == "__main__":
    raise SystemExit(main())
