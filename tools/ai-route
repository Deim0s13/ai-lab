#!/usr/bin/env python3

import argparse
import sys
from pathlib import Path

import yaml


ROOT = Path(__file__).resolve().parents[1]


def load_yaml(path: Path):
    if not path.exists():
        raise FileNotFoundError(str(path))

    with path.open() as handle:
        data = yaml.safe_load(handle)

    return data or {}


def format_list(values):
    if not values:
        return "none"
    return ", ".join(str(value) for value in values)


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Inspect AI workstation routing configuration without calling any provider."
    )
    parser.add_argument(
        "--profile",
        required=True,
        help="Profile name, for example macos-work, windows-personal, or fedora-atomic.",
    )
    parser.add_argument(
        "--explain",
        action="store_true",
        help="Explain configured route classes and selected profile posture.",
    )

    args = parser.parse_args()

    if not args.explain:
        print("FAIL ai-route is inspection-only. Use --explain.", file=sys.stderr)
        return 2

    routes_path = ROOT / "config" / "routing" / "routes.yaml"
    profile_path = ROOT / "profiles" / args.profile / "profile.yaml"

    try:
        routes = load_yaml(routes_path)
        profile = load_yaml(profile_path)
    except FileNotFoundError as exc:
        print(f"FAIL missing file: {exc}", file=sys.stderr)
        return 3
    except yaml.YAMLError as exc:
        print(f"FAIL YAML parse error: {exc}", file=sys.stderr)
        return 4

    route_classes = routes.get("route_classes", {})

    print(f"Profile: {args.profile}")
    print(f"Profile file: {profile_path.relative_to(ROOT)}")
    print(f"Profile status: {profile.get('status', 'unknown')}")
    print(f"Risk posture: {profile.get('risk_posture', 'unknown')}")
    print()

    print("Profile context posture")
    print(f"- allowed contexts: {format_list(profile.get('allowed_contexts'))}")
    print(f"- blocked contexts: {format_list(profile.get('blocked_contexts'))}")
    print()

    print("Configured route classes")
    if not route_classes:
        print("- none")
    else:
        for name, details in route_classes.items():
            route_type = details.get("type", "unknown")
            gateway_model_group = details.get("gateway_model_group", "unknown")
            print(f"- {name}: type={route_type}, gateway_model_group={gateway_model_group}")

    print()
    print("Execution")
    print("- provider called: no")
    print("- model called: no")
    print("- gateway called: no")
    print("- execution is delegated to LiteLLM or another configured gateway")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
